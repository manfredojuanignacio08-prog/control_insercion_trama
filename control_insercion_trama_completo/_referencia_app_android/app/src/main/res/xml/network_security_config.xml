<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Si el backend se sirve por HTTP (sin HTTPS), Android bloquea ese
        tráfico por defecto desde Android 9 — sin este archivo, TODOS los
        pedidos fallan con error de red aunque el backend esté andando.

        Acá se habilita la excepción SOLO para direcciones puntuales:
         - 10.0.2.2  → cómo el emulador de Android Studio ve el "localhost"
                       de la PC (para desarrollo).
         - Agregá abajo la IP o dominio de tu backend si lo servís por HTTP
                       (ej. la IP de tu PC en la red local).

        Si el backend está desplegado con HTTPS (ej. Render), este archivo
        NO hace falta para ese dominio: HTTPS pasa siempre.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Ejemplo: backend corriendo en una PC de tu red local -->
        <!-- <domain includeSubdomains="false">192.168.1.50</domain> -->
    </domain-config>
</network-security-config>
