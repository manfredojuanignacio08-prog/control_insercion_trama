# ─── Conexión a la base de datos del equipo (Supabase) ────────────────
#
# Opción A (recomendada): pegar la "Connection string" que da Supabase en
# Project Settings → Database → Connection string → URI. Reemplazar
# [YOUR-PASSWORD] por la contraseña real (la comparte el equipo, no es
# la que figura en el documento de la base de datos por seguridad).
#
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.rybhfvnvxpfujpqdlqnk.supabase.co:5432/postgres
DATABASE_URL=

# Opción B: las mismas variables pero sueltas (se usan solo si DATABASE_URL
# está vacío). Útil para correr una base local propia en desarrollo, en vez
# de conectarse a la base compartida del equipo.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=control_trama

# Supabase EXIGE conexión SSL. Si DATABASE_URL apunta a Supabase, esto tiene
# que estar en "true" sí o sí, o la conexión va a fallar.
PGSSL=true

# Máximo de conexiones simultáneas del pool hacia Postgres. El plan free de
# Supabase tiene un límite de conexiones directas compartido entre todo el
# equipo — no conviene subir esto sin necesidad real.
PG_POOL_MAX=10

# puerto del servidor Express
PORT=3000

# development | production — afecta el formato de logs (morgan)
NODE_ENV=development

# Dominios permitidos por CORS, separados por coma. Vacío = cualquier origen (solo para dev).
# Ejemplo en producción: CORS_ORIGIN=https://control-trama.miempresa.com
CORS_ORIGIN=

# Poner en "true" SOLO si el server corre detrás de un reverse proxy (Nginx, Render, etc.)
TRUST_PROXY=false

# Rate limiting de la API (por IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

